<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pearadmin.modules.chat.mapper.TChatSessionMapper">

    <resultMap type="TChatSession" id="TChatSessionResult">
        <result property="sessionId" column="session_id"/>
        <result property="userId" column="user_id"/>
        <result property="sessionType" column="session_type"/>
        <result property="sessionTitle" column="session_title"/>
        <result property="createTime" column="create_time"/>
        <result property="isTop" column="is_top"/>
        <result property="topTime" column="top_time"/>
    </resultMap>

    <select id="selectTChatSessionList" parameterType="TChatSession" resultMap="TChatSessionResult">
        select `session_id`,`user_id`,`session_type`,`session_title`,`create_time`,`is_top`,`top_time`
        from `t_chat_session`
        <where>
            <if test="userId != null  and userId != ''"> and `user_id` = #{userId}</if>
            <if test="sessionType != null "> and `session_type` = #{sessionType}</if>
            <if test="sessionTitle != null  and sessionTitle != ''"> and `session_title` = #{sessionTitle}</if>
            <if test="isTop != null"> and `is_top` = #{isTop}</if>
        </where>
        order by `is_top` desc, `top_time` desc, `create_time` desc
    </select>

    <delete id="deleteTChatSessionById" parameterType="String">
        delete from `t_chat_session` where `session_id` = #{sessionId}
    </delete>

</mapper>